    <!-- ==== Estimate Duration ==== -->
    <xsd:complexType name='EstimateDurationRequestType'>
        <xsd:complexContent>
            <xsd:extension    base='setOptionsType'>
                <xsd:attribute name='protocol'  type='xsd:string' use='required'/>
            </xsd:extension>
        </xsd:complexContent>
    </xsd:complexType>

    <xsd:complexType name='EstimateDurationResponseType'>
        <xsd:complexContent>
            <xsd:extension    base='setOptionsType'>
                <xsd:attribute name='protocol'            type='xsd:string' use='required'/>
                <xsd:attribute name='durationInSeconds'   type='xsd:double' use='required'/>
                <xsd:attribute name='error'               type='xsd:string' use='optional'/>
            </xsd:extension>
        </xsd:complexContent>
    </xsd:complexType>

    <!-- ==== Status ==== -->
    <xsd:complexType name='HardwareRequestType' />

    <xsd:complexType name='HardwareResponseType'>
        <xsd:sequence>
            <xsd:element name='SpinsolveSoftware'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:string'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='RemoteControlVersion'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:string'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='ConnectedToHardware'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='SpinsolveHardware' minOccurs='0' maxOccurs='1'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:string'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='SpinsolveType' minOccurs='0' maxOccurs='1'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:string'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='HardwareCapabilities' minOccurs='0' maxOccurs='1'>
                <xsd:complexType>
                    <xsd:sequence>
                        <xsd:element name='BitArray1'>
                            <xsd:simpleType>
                                <xsd:restriction base='xsd:unsignedInt'/>
                            </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name='BitArray2'>
                            <xsd:simpleType>
                                <xsd:restriction base='xsd:unsignedInt'/>
                            </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name='BitArray3'>
                            <xsd:simpleType>
                                <xsd:restriction base='xsd:unsignedInt'/>
                            </xsd:simpleType>
                        </xsd:element>
                        <xsd:element name='BitArray4'>
                            <xsd:simpleType>
                                <xsd:restriction base='xsd:unsignedInt'/>
                            </xsd:simpleType>
                        </xsd:element>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>

    <!-- ==== Explicit Shim Requests ==== -->
    <xsd:complexType name='CheckShimRequestType' />
    <xsd:complexType name='QuickShimRequestType' />
    <xsd:complexType name='PowerShimRequestType' />

    <xsd:complexType name='CheckShimResponseType'>
        <xsd:sequence>
            <xsd:element name='OperatingTemperature'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='StableTemperatures'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='StableLock'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='LineWidth'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:float'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='BaseWidth'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:float'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='SystemIsReady'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
        <xsd:attribute name='error' type='xsd:string' use='optional'/>
    </xsd:complexType>

    <xsd:complexType name='QuickShimResponseType'>
        <xsd:sequence>
            <xsd:element name='OperatingTemperature'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='StableTemperatures'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='StableLock'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='LineWidth'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:float'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='BaseWidth'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:float'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='SystemIsReady'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
        <xsd:attribute name='error' type='xsd:string' use='optional'/>
    </xsd:complexType>

    <xsd:complexType name='PowerShimResponseType'>
        <xsd:sequence>
            <xsd:element name='OperatingTemperature'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='StableTemperatures'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='StableLock'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='LineWidth'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:float'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='BaseWidth'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:float'/>
                </xsd:simpleType>
            </xsd:element>
            <xsd:element name='SystemIsReady'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:boolean'/>
                </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
        <xsd:attribute name='error' type='xsd:string' use='optional'/>
    </xsd:complexType>

	<xsd:complexType name='qNMRResponseType'>
		<xsd:sequence>
			<xsd:choice minOccurs='0' maxOccurs='unbounded'>
				<xsd:element name='Parameter'>
					<xsd:complexType>
						<xsd:attribute name='name'  type='xsd:string' use='required'/>
						<xsd:attribute name='value' type='xsd:string' use='required'/>
					</xsd:complexType>
				</xsd:element>
			</xsd:choice>
		</xsd:sequence>
		<xsd:attribute name='datafolder'            type='xsd:string' use='required'/>
		<xsd:attribute name='report_xml'            type='xsd:string' use='required'/>
		<xsd:attribute name='report_pdf'            type='xsd:string' use='required'/>
	</xsd:complexType>

    <!-- ==== Start ==== -->
    <xsd:complexType name='StartType'>
        <xsd:complexContent>
            <xsd:extension    base='setOptionsProcessingType'>
                <xsd:attribute name='protocol'            type='xsd:string' use='required'/>
            </xsd:extension>
        </xsd:complexContent>
    </xsd:complexType>

	<!-- ==== qNMR ==== -->
	<xsd:complexType name='qNMRRequestType'>
		<xsd:sequence>
			<xsd:element name='Sample'  type='xsd:string'/>
			<xsd:element name='Solvent' type='xsd:string'/>
			<xsd:element name='Custom'  type='xsd:string'/>
			<xsd:choice minOccurs='0' maxOccurs='unbounded'>
				<xsd:element name='Parameter'>
					<xsd:complexType>
						<xsd:attribute name='name'  type='xsd:string' use='required'/>
						<xsd:attribute name='value' type='xsd:string' use='required'/>
					</xsd:complexType>
				</xsd:element>
			</xsd:choice>
		</xsd:sequence>
		<xsd:attribute name='method'              type='xsd:string' use='required'/>
		<xsd:attribute name='measurement'         type='xsd:string' use='required'/>
	</xsd:complexType>
	
	<!-- ==== Abort ==== -->
    <xsd:complexType name='AbortType' />

    <!-- ==== Script ==== -->
    <xsd:complexType name='ExecuteType'>
        <xsd:sequence>
            <xsd:element name='Script' minOccurs='1' maxOccurs='1'>
                <xsd:simpleType>
                    <xsd:restriction base='xsd:string' />
                </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>

    <!-- ==== Status Notification ==== -->
    <xsd:complexType name='StatusNotificationType'>
        <xsd:choice>
            <xsd:element name='State'                        type='StateNotificationType'             minOccurs='0' />
            <xsd:element name='Error'                        type='ErrorNotificationType'             minOccurs='0' />
            <xsd:element name='Progress'                     type='ProgressNotificationType'          minOccurs='0' />
            <xsd:element name='Completed'                    type='CompletedNotificationType'         minOccurs='0' />
        </xsd:choice>
        <xsd:attribute name='timestamp' type='xsd:string' use='required'/>
    </xsd:complexType>

    <!-- ==== State Notification ==== -->
    <xsd:complexType name='StateNotificationType'>
        <xsd:attribute name='protocol'          type='xsd:string'   use='required'/>
        <xsd:attribute name='status' use='required'>
            <xsd:simpleType>
                <xsd:restriction base='xsd:string'>
                    <xsd:enumeration value='Ready'/>
                    <xsd:enumeration value='Running'/>
                    <xsd:enumeration value='Stopping'/>
                </xsd:restriction>
            </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name='dataFolder'        type='xsd:string'   use='required'/>
    </xsd:complexType>

    <!-- ==== Progress Notification ==== -->
    <xsd:complexType name='ProgressNotificationType'>
        <xsd:attribute name='protocol'          type='xsd:string'   use='required'/>
        <xsd:attribute name='percentage'        type='xsd:int'      use='required'/>
        <xsd:attribute name='secondsRemaining'  type='xsd:int'      use='required'/>
    </xsd:complexType>

    <!-- ==== Completed Notification ==== -->
    <xsd:complexType name='CompletedNotificationType'>
        <xsd:attribute name='protocol'          type='xsd:string'   use='required'/>
        <xsd:attribute name='completed'         type='xsd:boolean'  use='required'/>
        <xsd:attribute name='successful'        type='xsd:boolean'  use='required'/>
    </xsd:complexType>

    <!-- ==== Error Notification ==== -->
    <xsd:complexType name='ErrorNotificationType'>
        <xsd:attribute name='protocol'          type='xsd:string'   use='required'/>
        <xsd:attribute name='error'             type='xsd:string'   use='required'/>
    </xsd:complexType>

</xsd:schema>
