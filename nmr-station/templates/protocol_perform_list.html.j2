<div id="protocol-list" >

  <div class="field-wrapper"> List of Planned Protocols </div>
  <button id="get-protocol-selection-btn" hx-get="/get_protocol_selection" hx-target="#protocol-config"> Add new protocol </button>

{% for obj in protocols %}
  <div id="protocol-item-{{loop.index}}" class="field-wrapper">
    <span> {{ loop.index }} </span>
    <span> {{ obj['protocol'] }} </span>
    <button class="delete-btn" id="delete-protocol-item-{{loop.index}}" hx-delete="/protocol-item/{{loop.index}}" hx-target="#protocol-list">Delete</button>
  </div>
{% endfor %}
</div>